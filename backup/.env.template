# =============================================================================
# Restic + Backblaze B2 - Variables de entorno
# Copiar como .env y completar valores
#
# Obtener credenciales en: https://www.backblaze.com/app-keys
# Crear una Application Key con acceso limitado al bucket de backup.
# =============================================================================

# ─── Backblaze B2 ─────────────────────────────────────────────────────────────
B2_ACCOUNT_ID=TU_KEY_ID_AQUI
B2_ACCOUNT_KEY=TU_APPLICATION_KEY_AQUI
B2_BUCKET=nombre-de-tu-bucket

# ─── Restic ───────────────────────────────────────────────────────────────────
# Contraseña de cifrado del repositorio. GUARDAR ESTE VALOR EN LUGAR SEGURO.
# Si se pierde, los backups son irrecuperables.
RESTIC_PASSWORD=CAMBIAR_CONTRASEÑA_REPOSITORIO

# ─── Rutas ────────────────────────────────────────────────────────────────────
DOCKERS_DIR=/home/santiagopaleka/dockers
MEDIA_DISK=/mnt/discocho

# ─── Retención (cuántos backups conservar) ────────────────────────────────────
# 7 diarios, 4 semanales, 6 mensuales
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6
