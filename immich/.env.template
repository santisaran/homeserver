# =============================================================================
# Immich - Variables de entorno
# Copiar como .env y completar valores
# =============================================================================

# Ruta donde se guardarán las fotos y la base de datos
UPLOAD_LOCATION=/mnt/discocho/immich

# Versión de Immich ("release" = última estable)
IMMICH_VERSION=release

# Base de datos
DB_USERNAME=immich
DB_PASSWORD=CAMBIAR_PASSWORD_DB
DB_DATABASE_NAME=immich

# (No modificar - lo usa el servidor internamente)
DB_HOSTNAME=database
REDIS_HOSTNAME=redis
